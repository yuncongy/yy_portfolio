# YY Portfolio — local setup and project map
#
# Run locally (this project uses pnpm):
#   pnpm install
#   pnpm dev
# Then visit http://localhost:3000.
#
# Where things live:
# - src/app/            Next.js routes, layouts, and page styles.
# - src/app/projects/   Individual project pages and dynamic project routes.
# - src/components/     Reusable site and UI components.
# - src/lib/            Shared utilities and project data.
# - public/             Static files served directly (images, media, resume).
# - package.json        Scripts and dependency definitions.

# Dependencies
node_modules/

# Next.js build and development output
.next/
out/

# Local environment files (keep example files trackable)
.env*
!.env.example

# Logs and debug output
*.log
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and operating-system files
.DS_Store
.idea/
.vscode/

# TypeScript build metadata
*.tsbuildinfo
